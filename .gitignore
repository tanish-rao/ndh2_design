# Logs
logs/
*.log
*.out
*.err

# Slurm job files
*.sbatch

# Large generated files
*.bin
*.pt
*.safetensors
*.pth
*.pkl
*.h5
*.hdf5

# Generated sequences and structures
*.pdb
*.fasta
*.fa
*.txt

# Allow tracking FASTA only for pipeline result summaries
!filter_outputs/pipeline_results/*.fasta
!filter_outputs/pipeline_results/*.fa
generated_*/
filtered_*/

# Model checkpoints
checkpoint*/
checkpoints/
model_*.bin
pytorch_model*.bin

# Temporary files
tmp/
temp/
*.tmp
*.swp
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.sublime-*

# OS
.DS_Store
Thumbs.db

# Data files
*.csv
*.tsv
*.xlsx
*.json

# Docking files
*.pdbqt
*.gpf
*.glg
*.dlg

# DFT files
*.gbw
*.inp
*.bibtex
*.densities
*.densitiesinfo
# Exclude heavy outputs from acquire_homologs (screening/results)
acquire_homologs/outputs*/
acquire_homologs/**/outputs*/
acquire_homologs/**/hmmer_screen/
acquire_homologs/**/hmmer*/
acquire_homologs/**/candidates*.fa*

# Exclude heavy work dirs and artifacts in top-level pipeline_results
pipeline_results/*_work/
pipeline_results/**/tier6_docking_work/
pipeline_results/**/tier7_dft_work/
pipeline_results/**/homolog_docking_work/
pipeline_results/**/homolog_structures/
pipeline_results/**/*.pdbqt
pipeline_results/**/*.gbw
pipeline_results/**/*.inp
pipeline_results/**/*.bibtex
pipeline_results/**/*.densities*
